# Example keystore for the provenance HMAC signer.
#
# Operators ship this file out-of-band, set it to mode 0400, and point
# `keystore_path` in manifest.toml at it. Rotate by writing a new file
# with a fresh `key_id` and `key_hex` and updating the manifest. The
# old `key_id` is what older `ReadProvenance` receipts cite, so old
# audits keep verifying as long as the historical key is reachable
# through whatever `ProvenanceKeystore` you wire up downstream.
#
# `key_hex` must decode to >= 32 bytes (256-bit HMAC-SHA256 key).
# Generate with: `openssl rand -hex 32`.

key_id = "mnemo-prov-2026-04"
key_hex = "00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff"
